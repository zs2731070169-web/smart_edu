# 复制此文件为 .env 并填入真实值，.env 不提交到 Git

# LLM API 配置
CLOSEAI_API_KEY=你的API密钥
CLOSEAI_BASE_URL=https://api.openai-proxy.org/v1

# MySQL 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=smart_edu_user
MYSQL_PASSWORD=你的MySQL密码
MYSQL_DATABASE=smart_edu

# Neo4j 图数据库
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=你的Neo4j密码

# Session 密钥（随机字符串）
SESSION_SECRET_KEY=随机生成的强密钥
