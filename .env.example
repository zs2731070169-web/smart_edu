# 复制此文件为 .env 并填入真实值，.env 不提交到 Git

# LLM API 配置（NEWCOIN 平台）
NEWCOIN_API_KEY=你的NEWCOIN密钥
NEWCOIN_BASE_URL=https://api.newcoin.top/v1

# LLM API 配置（CLOSEAI 平台）
CLOSEAI_API_KEY=你的CLOSEAI密钥
CLOSEAI_BASE_URL=https://api.openai-proxy.org/v1

# MySQL 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=你的MySQL密码
MYSQL_DATABASE=smart_edu

# Neo4j 图数据库
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=你的Neo4j密码

# Session 密钥（随机字符串）, 用命令 python3 -c "import secrets; print(secrets.token_hex(32))" 生成
SESSION_SECRET_KEY=随机生成的强密钥

# 是否开启 Agent 对话记忆（true/false）
AGENT_WITH_MEMORY=true
